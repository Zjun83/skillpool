# ── Application ──────────────────────────────────
APP_NAME=skillpool
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ── Database ────────────────────────────────────
DATABASE_URL=sqlite:///./skillpool.db
DB_ECHO=false

# ── Authentication ──────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
API_KEY_ENABLED=true
API_KEY=sk-test-change-me

# ── Bridge / WAL ───────────────────────────────
BRIDGE_WAL_DIR=./data/wal
BRIDGE_AUTO_MAINTENANCE=true
BRIDGE_FREEZE_DETECTION=true
BRIDGE_FREEZE_TIMEOUT_SEC=300

# ── Audit ──────────────────────────────────────
AUDIT_ENABLED=true
AUDIT_LOG_DIR=./data/audit

# ── Telemetry ──────────────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=http://localhost:4317

# ── Adapter Defaults ───────────────────────────
DEFAULT_ADAPTER=codex
